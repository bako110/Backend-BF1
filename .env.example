# ─── MongoDB ────────────────────────────────────────────────────────────────
# En mode Docker Compose, MONGODB_URI est remplacé automatiquement par le service mongo local.
# En dehors de Docker, décommentez et configurez l'URI Atlas.
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/Bf1_db?retryWrites=true&w=majority
MONGODB_DBNAME=bf1_db

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_secret_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Email ──────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_email_user
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@bf1.com

# ─── Redis (désactivé par défaut) ───────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ─── Application ────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
RATE_LIMIT_PER_MINUTE=60
ALLOWED_ORIGINS_STR=http://localhost:3000,http://127.0.0.1:3000

# ─── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Flux live ──────────────────────────────────────────────────────────────
LIVE_HLS_URL=
LIVE_DAILYMOTION_URL=

# ─── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/users/auth/google/callback
FRONTEND_URL=http://localhost:3000


# ─── Firebase ───────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
